# Backend local environment
# Copy to backend/.env when running the FastAPI service locally.

APP_NAME="AI Azure Well-Architected Review Assistant API"
APP_ENV=local
DEBUG=false
API_PREFIX=/api/v1
PUBLIC_API_BASE_URL=http://localhost:8000

AUTH_MODE=local
AUTH_TENANT_ID=00000000-0000-0000-0000-000000000000
AUTH_AUDIENCE=api://ai-azure-waf-review-assistant
AUTH_ALLOW_LOCAL_TOKENS=true

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/waf_reviews
REDIS_URL=redis://localhost:6379/0

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_SEARCH_ENDPOINT=
AZURE_STORAGE_ACCOUNT_URL=
AZURE_SERVICE_BUS_FULLY_QUALIFIED_NAMESPACE=
