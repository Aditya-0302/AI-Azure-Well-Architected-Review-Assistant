APP_NAME="AI Azure Well-Architected Review Assistant API"
APP_ENV=local
DEBUG=false
API_PREFIX=/api/v1
PUBLIC_API_BASE_URL=http://localhost:8000

LOG_LEVEL=INFO
LOG_JSON=true

AUTH_MODE=local
AUTH_TENANT_ID=00000000-0000-0000-0000-000000000000
AUTH_ISSUER=
AUTH_AUDIENCE=api://ai-azure-waf-review-assistant
AUTH_JWKS_URL=
AUTH_ALLOW_LOCAL_TOKENS=true

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/waf_reviews
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_PREFIX=waf

AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_RAW=raw
AZURE_STORAGE_CONTAINER_NORMALIZED=normalized
AZURE_STORAGE_CONTAINER_REPORTS=reports

RAG_INDEX_NAME=knowledge
RAG_EMBEDDING_DIMENSIONS=3072
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=180
RAG_SEMANTIC_CONFIGURATION_NAME=waf-semantic-config
RAG_VECTOR_PROFILE_NAME=waf-vector-profile
RAG_VECTOR_ALGORITHM_NAME=waf-hnsw
RAG_DEFAULT_TOP_K=8

AZURE_SERVICE_BUS_FULLY_QUALIFIED_NAMESPACE=
SERVICE_BUS_INGESTION_QUEUE=ingestion-jobs
SERVICE_BUS_REVIEW_QUEUE=review-jobs
SERVICE_BUS_REPORT_QUEUE=report-jobs
